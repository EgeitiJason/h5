#vi skaber et DHCP Scope for klienter i rækkeviden 10.0.20.100-110
Add-Dhcpserverv4scope -Name "client Scope" -StartRange 10.0.20.100 -EndRange 10.0.20.110

#vi definerer domain name for vores scope
Set-DhcpServerv4OptionValue -ScopeId 10.0.20.0 -OptionId 15 -Value "prutl.internal"

#vi tilføjer en dns server der pejer på vores DC
Set-DhcpServerv4OptionValue -ScopeId 10.0.20.0 -OptionId 6 -Value 10.0.10.10

#vi opsætter en default gateway for vores scope
Set-DhcpServerv4OptionValue -ScopeId 10.0.20.0 -OptionId 3 -Value 10.0.20.1

#vi sætter en lease time på 1 time
Set-DhcpServerv4Scope -ScopeId 10.0.20.0 -LeaseDuration 01:00:00